# MikroTik Password Bot — Configuration
# Copy this file to telegram_bot.config and fill in your values.
# Lines starting with # are ignored.

# Bot token from @BotFather
BOT_TOKEN = 

# Telegram group chat ID (negative number)
# Run: python mikrotik_bot.py --getgroupid to find this
GROUP_CHAT_ID = 

# SSH username used for temp password rotation
# Must match the username used in mikrotik_passmanager.py
SSH_USERNAME = manager

USERS_PASSWORDS_FILE = 
